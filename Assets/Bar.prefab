    \"For Pad Under Here\",\r\n\"tutorial\": \"\uC0AC\uC6A9\uBC95\",\r\n\"extractingEspresso\":
    \"\uC5D0\uC2A4\uD504\uB808\uC18C \uCD94\uCD9C\",\r\n\"extractingEspresso_1_title\":
    \"1. \uCEE4\uD53C \uCF69 \uBD84\uC1C4\uD558\uAE30\",\r\n\"extractingEspresso_1_content\":
    \"\uBE48 \uD544\uD130\uB97C \uADF8\uB77C\uC778\uB354\uC5D0 \uC62C\uB824\uB193\uC2B5\uB2C8\uB2E4.\\n\uADF8\uB77C\uC778\uB354\uC758
    \uBC84\uD2BC\uC744 \uB20C\uB7EC \uBD84\uC1C4\uB97C \uC2DC\uC791\uD569\uB2C8\uB2E4.\",\r\n\"extractingEspresso_2_title\":
    \"2. \uD544\uD130 \uD0EC\uD551\uD558\uAE30\",\r\n\"extractingEspresso_2_content\":
    \"\uD0EC\uD37C\uB97C \uC774\uC6A9\uD558\uC5EC \uBD84\uC1C4\uB41C \uCF69\uC774
    \uB2F4\uAE34 \uD544\uD130\uB97C \uD0EC\uD551\uD569\uB2C8\uB2E4.\",\r\n\"extractingEspresso_3_title\":
    \"3. \uBA38\uC2E0 \uC138\uD305 \uBC0F \uCD94\uCD9C\uD558\uAE30\",\r\n\"extractingEspresso_3_content\":
    \"\uD544\uD130\uB97C \uB4E4\uACE0 \uD074\uB9AD\uD558\uC5EC \uC6D0\uD558\uB294
    \uB178\uC990\uB85C \uBCC0\uACBD\uD569\uB2C8\uB2E4.\\n\uD0EC\uD551\uB41C \uD544\uD130\uB97C
    \uBA38\uC2E0\uC5D0 \uC7A5\uCC29\uD569\uB2C8\uB2E4.\\n\uC870\uC808\uB41C \uB178\uC990\uC5D0
    \uB9DE\uAC8C \uD45C\uC2DC\uB41C \uC544\uB798\uC758 \uADF8\uB9BC\uC790\uC5D0 \uBE48
    \uC5D0\uC2A4\uD504\uB808\uC18C \uCEF5\uC744 \uB193\uC2B5\uB2C8\uB2E4.\\n\uBA38\uC2E0\uC758
    \uC138\uBC88\uC9F8 \uBC84\uD2BC\uC744 \uB20C\uB7EC \uCD94\uCD9C\uC744 \uC2DC\uC791\uD569\uB2C8\uB2E4.\",\r\n\"extractingEspresso_4_title\":
    \"4. \uD544\uD130 \uBE44\uC6B0\uAE30\",\r\n\"extractingEspresso_4_content\":
    \"\uC0AC\uC6A9\uB41C \uD544\uD130\uB294 \uB109\uBC15\uC2A4(Knock Box)\uC5D0 \uB450\uB4DC\uB824\uC11C
    \uBE44\uC6C1\uB2C8\uB2E4.\",\r\n\"frothingMilk\": \"\uC6B0\uC720 \uAC70\uD488\",\r\n\"frothingMilk_1_title\":
    \"1. \uC6B0\uC720 \uB530\uB974\uAE30\",\r\n\"frothingMilk_1_content\": \"\uC6B0\uC720
    \uD329\uC744 \uB4E4\uACE0 \uD074\uB9AD\uD558\uC5EC \uB69C\uAED1\uC744 \uC5FD\uB2C8\uB2E4.\\n\uC6B0\uC720
    \uD329\uC744 \uAE30\uC6B8\uC5EC \uBE48 \uD53C\uCC98\uC5D0 \uC6B0\uC720\uB97C
    \uB530\uB985\uB2C8\uB2E4.\",\r\n\"frothingMilk_2_title\": \"2. \uBA38\uC2E0 \uC138\uD305
    \uBC0F \uAC70\uD488 \uB0B4\uAE30\",\r\n\"frothingMilk_2_content\": \"\uC6B0\uC720\uAC00
    \uB4E0 \uD53C\uCC98\uB97C \uBA38\uC2E0\uC758 \uB178\uC990\uC5D0 \uC7A5\uCC29\uD569\uB2C8\uB2E4.\\n\uBA38\uC2E0\uC758
    4\uBC88\uC9F8 \uBC84\uD2BC\uC744 \uB20C\uB7EC \uBAA8\uB4DC\uB97C \uBCC0\uACBD\uD569\uB2C8\uB2E4.\\n\uBA38\uC2E0
    \uC624\uB978\uCABD\uC758 \uBC84\uD2BC\uC744 \uB20C\uB7EC \uAC70\uD488\uB0B4\uAE30\uB97C
    \uC2DC\uC791\uD569\uB2C8\uB2E4.\",\r\n\"frothingMilk_3_title\": \"3. \uC8FC\uC758\uC0AC\uD56D\",\r\n\"frothingMilk_3_content\":
    \"\uC6B0\uC720\uAC00 \uB4E0 \uD53C\uCC98\uB97C \uAE30\uC6B8\uC778 \uB4A4 \uD074\uB9AD\uD558\uC5EC
    \uB0B4\uC6A9\uBB3C\uC744 \uB530\uB77C\uB0C5\uB2C8\uB2E4.\\n\uC798\uBABB \uC870\uC900\uD558\uC5EC
    \uB0B4\uC6A9\uBB3C\uC744 \uBC84\uB9AC\uC9C0 \uC54A\uB3C4\uB85D \uC870\uC2EC\uD569\uB2C8\uB2E4.\",\r\n\"whippedCream\":
    \"\uD718\uD551\uD06C\uB9BC\",\r\n\"whippedCream_1_content\": \"\uD06C\uB9BC \uB514\uC2A4\uD39C\uC11C\uB97C
    \uC774\uC6A9\uD558\uC5EC \uBAA8\uB4E0 \uC885\uB958\uC758 \uC644\uC131\uB41C \uC74C\uB8CC
    \uC704\uC5D0 \uD718\uD551\uD06C\uB9BC\uC744 \uC62C\uB9B4 \uC218 \uC788\uC2B5\uB2C8\uB2E4.\",\r\n\"whippedCream_2_content\":
    \"\uC644\uC131\uB41C \uC74C\uB8CC \uC704\uC5D0 \uD30C\uC6B0\uB354\uB098 \uC2DC\uB7FD\uC774
    \uC788\uC73C\uBA74 \uD718\uD551\uD06C\uB9BD\uC744 \uC62C\uB9B4 \uC218 \uC5C6\uC2B5\uB2C8\uB2E4.\",\r\n\"whippedCream_3_content\":
    \"\uAE30\uD638\uC5D0 \uB9DE\uAC8C \uD06C\uB9BC \uC704\uC5D0 \uD30C\uC6B0\uB354\uB098
    \uC2DC\uB7FD\uC744 \uBFCC\uB824 \uB9C8\uBB34\uB9AC \uD560 \uC218 \uC788\uC2B5\uB2C8\uB2E4.\",\r\n\"dishesAndIce\":
    \"\uADF8\uB987, \uC5BC\uC74C\",\r\n\"dishesAndIce_1_title\": \"\uC811\uC2DC\",\r\n\"dishesAndIce_1_content\":
    \"\uC5D0\uC2A4\uD504\uB808\uC18C \uC794\uACFC \uCEE4\uD53C \uC794\uC740 \uAC01\uC790
    \uD06C\uAE30\uC5D0 \uB9DE\uB294 \uC811\uC2DC\uC5D0 \uC62C\uB824\uB193\uC744 \uC218
    \uC788\uC2B5\uB2C8\uB2E4.\",\r\n\"dishesAndIce_2_title\": \"\uBE68\uB300\",\r\n\"dishesAndIce_2_content\":
    \"\uC544\uC774\uC2A4 \uC74C\uB8CC\uB97C \uB9CC\uB4E4 \uC218 \uC788\uB294 \uC720\uB9AC
    \uC794\uC740 \uBE68\uB300\uB97C \uC0AC\uC6A9\uD560 \uC218 \uC788\uC2B5\uB2C8\uB2E4.\",\r\n\"dishesAndIce_3_title\":
    \"\uC124\uAC70\uC9C0\",\r\n\"dishesAndIce_3_content\": \"\uB354\uB7FD\uAC70\uB098
    \uB0B4\uC6A9\uBB3C\uC774 \uB0A8\uC740 \uC2DD\uAE30\uB294 \uC2F1\uD06C\uB300\uC758
    \uBB3C\uC5D0 \uB2F4\uAC00 \uC53B\uC5B4\uB0BC \uC218 \uC788\uC2B5\uB2C8\uB2E4.\",\r\n\"dishesAndIce_4_title\":
    \"\uC5BC\uC74C\",\r\n\"dishesAndIce_4_content\": \"\uC720\uB9AC\uCEF5\uC73C\uB85C
    \uC5BC\uC74C \uC815\uC218\uAE30\uC758 \uBC84\uD2BC\uC744 \uD130\uCE58\uD558\uBA74
    \uC5BC\uC74C\uC744 \uBC1B\uC744 \uC218 \uC788\uC2B5\uB2C8\uB2E4.\",\r\n\"recipe\":
    \"\uB808\uC2DC\uD53C\",\r\n\"coffeeHot\": \"\uB728\uAC70\uC6B4 \uCEE4\uD53C\",\r\n\"coffeeIced\":
    \"\uC544\uC774\uC2A4 \uCEE4\uD53C\",\r\n\"option\": \"\uC635\uC158\",\r\n\"cupCoffee\":
    \"\uCEE4\uD53C \uC794\",\r\n\"cupEspresso\": \"\uC5D0\uC2A4\uD504\uB808\uC18C
    \uC794\",\r\n\"cupGlass\": \"\uC720\uB9AC \uCEF5\",\r\n\"cupMug\": \"\uBA38\uADF8\uC794\",\r\n\"ice\":
    \"\uC5BC\uC74C\",\r\n\"espressoCaramel\": \"\uCE74\uB77C\uBA5C \uC2DC\uB7FD\uC774
    \uD63C\uD569\uB41C \uC5D0\uC2A4\uD504\uB808\uC18C\",\r\n\"waterHot\": \"\uB728\uAC70\uC6B4
    \uBB3C\",\r\n\"waterCold\": \"\uCC28\uAC00\uC6B4 \uBB3C\",\r\n\"milk\": \"\uC6B0\uC720\",\r\n\"milkLatte\":
    \"\uB77C\uB5BC \uAC70\uD488 \uC6B0\uC720\",\r\n\"milkCappuccino\": \"\uCE74\uD478\uCE58\uB178
    \uAC70\uD488 \uC6B0\uC720\",\r\n\"powderCinamon\": \"\uC2DC\uB098\uBAAC \uD30C\uC6B0\uB354\",\r\n\"powderChocolate\":
    \"\uCD08\uCF5C\uB81B \uD30C\uC6B0\uB354\",\r\n\"syrupCaramel\": \"\uCE74\uB77C\uBA5C
    \uC2DC\uB7FD\",\r\n\"syrupChocolate\": \"\uCD08\uCF5C\uB81B \uC2DC\uB7FD\",\r\n\"mocha_powderOrSyrup\":
    \"\uCD08\uCF5C\uB81B\\n\uD30C\uC6B0\uB354 \uB610\uB294 \uC2DC\uB7FD\",\r\n\"config\":
    \"\uC124\uC815\",\r\n\"config_resetPosition\": \"\uC704\uCE58 \uCD08\uAE30\uD654\",\r\n\"config_all\":
    \"\uBAA8\uB450\",\r\n\"config_tools\": \"\uB3C4\uAD6C\",\r\n\"config_cups\":
    \"\uCEF5\",\r\n\"config_ingredients\": \"\uC7AC\uB8CC\",\r\n\"config_plates\":
    \"\uC811\uC2DC\",\r\n\"info_contact_title\": \"\uBB38\uC758\",\r\n\"info_contact_content\":
    \"\uBC84\uADF8\uB97C \uBC1C\uACAC\uD588\uAC70\uB098 \uCEE4\uD53C \uC138\uD2B8\uC5D0
    \uAD00\uD574 \uAD81\uAE08\uD55C \uC810\uC774 \uC788\uC744 \uB550 \uB514\uC2A4\uCF54\uB4DC\uB97C
    \uD1B5\uD558\uC5EC \uC5F0\uB77D \uBD80\uD0C1\uB4DC\uB9BD\uB2C8\uB2E4.\",\r\n\"lemon\":
    \"\uB808\uBAAC\",\r\n\"greenGrape\": \"\uCCAD\uD3EC\uB3C4\",\r\n\"grapefruit\":
    \"\uC790\uBABD\",\r\n\"strawberry\": \"\uB538\uAE30\",\r\n\"sparklingWater\":
    \"\uD0C4\uC0B0\uC218\",\r\n\"menuAde\": \"\uB808\uBAAC\\n\uCCAD\uD3EC\uB3C4\\n\uC790\uBABD\\n\uB538\uAE30\",\r\n\"recipeAde_garnish\":
    \"\uD5C8\uBE0C\uC640 \uACFC\uC77C \uAC00\uB2C8\uC26C\",\r\n\"recipeAde_base\":
    \"\uB808\uBAAC \uC999 \uB610\uB294 \uC790\uBABD \uC999,\\n\uCCAD\uD3EC\uB3C4
    \uCCAD \uB610\uB294 \uB538\uAE30 \uCCAD\"\r\n}"
