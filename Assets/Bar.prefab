  - "{\r\n\"langName\": \"\u65E5\u672C\u8A9E\",\r\n\"langCode\": \"jp\",\r\n\"langFont\":
    \"NotoSansJP\",\r\n\"-----comment-Menu-----\": \"For Menu Plate Under Here\",\r\n\"info\":
    \"\u60C5\u5831\",\r\n\"infoQR\": \"\u5F8C\u308D\u306BQR\u30B3\u30FC\u30C9\u304C\u3042\u308A\u307E\u3059\",\r\n\"needDLC\":
    \"DLC\u304C\u5FC5\u8981\u3067\u3059\",\r\n\"commingSoon\": \"\u8FD1\u65E5\u516C\u958B\",\r\n\"coffee\":
    \"\u30B3\u30FC\u30D2\u30FC\",\r\n\"ade\": \"\u30A8\u30FC\u30C9\",\r\n\"bubbleTea\":
    \"\uF9FE\",\r\n\"espresso\": \"\u30A8\u30B9\u30D7\u30EC\u30C3\u30BD\",\r\n\"espressoConPanna\":
    \"\u30A8\u30B9\u30D7\u30EC\u30C3\u30BD\u30B3\u30F3\u30D1\u30CA\",\r\n\"americano\":
    \"\u30A2\u30E1\u30EA\u30AB\u30FC\u30CE\",\r\n\"latte\": \"\u30E9\u30C6\",\r\n\"cappuccino\":
    \"\u30AB\u30D7\u30C1\u30FC\u30CE\",\r\n\"cafeMocha\": \"\u30AB\u30D5\u30A7\u30E2\u30AB\",\r\n\"cafeMochaArt\":
    \"\u30AB\u30D5\u30A7\u30E2\u30AB\uFF08\u30A2\u30FC\u30C8\uFF09\",\r\n\"caramelMacchiato\":
    \"\u30AD\u30E3\u30E9\u30E1\u30EB\u30DE\u30AD\u30A2\u30FC\u30C8\",\r\n\"-----comment-Machine-----\":
    \"For Espresso Machine Under Here\",\r\n\"machine_filterNeed\": \"\u30DD\u30FC\u30BF\u30D5\u30A3\u30EB\u30BF\u30FC\u5FC5\u8981\",\r\n\"machine_filterNeedTamped\":
    \"\u30BF\u30F3\u30D1\u3055\u308C\u305F\\n\u30DD\u30FC\u30BF\u30D5\u30A3\u30EB\u30BF\u30FC\u5FC5\u8981\",\r\n\"machine_filterPlaced\":
    \"\u30D5\u30A3\u30EB\u30BF\u30FC\\n\u8A2D\u7F6E\u6E08\u307F\",\r\n\"machine_filterChange\":
    \"\u30D5\u30A3\u30EB\u30BF\u30FC\\n\u4EA4\u63DB\u5FC5\u8981\",\r\n\"machine_cupNeed\":
    \"\u30A8\u30B9\u30D7\u30EC\u30C3\u30BD\\n\u30AB\u30C3\u30D7\u5FC5\u8981\",\r\n\"machine_cupNeedEmpty\":
